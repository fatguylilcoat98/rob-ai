# Splendor — The Remarkable AI Environment Variables
# Copy this to .env and fill in your values

# AI Provider APIs
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Pinecone Configuration (Semantic Memory)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=splendor-memory

# Tavily Configuration (Web Search)
TAVILY_API_KEY=your_tavily_api_key_here

# ElevenLabs (Voice — falls back to browser TTS if missing)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development# ModelsLab Configuration (Video Generation)
MODELSLAB_API_KEY=your_modelslab_api_key_here
